ff
main(args, a)
    call html(args)
	set str haystack is 'hello x world'
    set str needle is 'world'    
    set str out_value is ' '
    set nr FALSE is 0
    call cut(haystack, needle, out_value, FALSE)

    set ref out_value is cut out
    !print('...aaand the winner is:', out_value)

