        '<script>alert("', my_content ,'");</script>',
        '</html>')

ff 
cut(haystack, needle, out, dbug)
    set nr needle_start is 0
    set nr one is 1
    set nr needle_idx is 0
    !pos(needle, haystack, needle_idx)
    if dbug eq '1'
        !print('needle_start:', needle_start)
        !print('needle_idx:', needle_idx)
    end
    if haystack contains needle
        if dbug eq '1'
            !print('needle found in haystack!')
        end
        !substr(needle_start, needle_idx, haystack, out)
        if dbug eq '1'
            !print('haystack:', haystack)
        end
    end
